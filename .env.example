# Base URL used for canonical links, sitemap, and OG/Twitter metadata.
NEXT_PUBLIC_SITE_URL=https://jairojgarcia.com

# Mailchimp — used by app/api/subscribe/route.ts for the free-masterclass
# email capture. API key looks like "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-us21"
# (the "-us21" suffix is the datacenter, derived automatically at request
# time — no separate env var needed for it). Audience ID is found under
# Mailchimp > Audience > Settings > Audience name and defaults.
MAILCHIMP_API_KEY=
MAILCHIMP_AUDIENCE_ID=
